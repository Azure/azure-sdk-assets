            "container_id": "cntr_6a188e6bc9b481908d246f33ee28b353020e6a30898f99ea",
            "code": "import numpy as np\nimport matplotlib.pyplot as plt\n\n# Define the function\ndef f(x):\n    return np.sin(x) + x**2 - 42\n\n# Plot the function in a range\nx = np.linspace(-10, 10, 400)\ny = f(x)\n\nplt.plot(x, y, label=\"f(x) = sin(x) + x^2 - 42\")\nplt.axhline(0, color='red', linestyle='--')\nplt.xlabel('x')\nplt.ylabel('f(x)')\nplt.grid(True)\nplt.title('Plot of the Function')\nplt.legend()\nplt.show()",
            "outputs": null
