            "output": "{\n        \"documents\": [\n          {\n            \"id\": \"121def41-912e-4778-9da4-67d0012b963f\",\n            \"content\": \"I can't access or provide actual sales records or field lists from the available data sources, as there is no sales data present in the systems I can use.\\n\\nIf you meant to ask about a database or data related to weather events, please clarify or ask a question related to that, as that is the data currently available.\\n\\nIf you have sales data in a specific database available on this platform, please specify its location or name so I can assist you with that. Otherwise, regarding sales data, I am unable to fetch or provide examples or field lists.\\n\",\n            \"filepath\": \"fabric://response\",\n            \"title\": \"Fabric Response for: sales records overview definition typical fields examples sales record\",\n            \"url\": \"https://msit.fabric.microsoft.com/groups/409e30ce-b2ad-4c80-a54d-d645227322e4/aiskills/98042b9e-11cb-422d-bd97-5873411aa7c8/stage/published/threads/thread_WatzbMTVrhyTOLRUqs5Fgelj/runs/run_fabNNEICp0FQbb1dvSGoqHcauaIR/question/msg_iP4meOCcApZNjjh2kynrCsiL/source/foundry\",\n            \"metadata\": \"{\\\"source\\\":\\\"azure_fabric\\\",\\\"query\\\":\\\"sales records overview definition typical fields examples sales record\\\",\\\"data_agent_url\\\":\\\"https://msit.fabric.microsoft.com/groups/409e30ce-b2ad-4c80-a54d-d645227322e4/aiskills/98042b9e-11cb-422d-bd97-5873411aa7c8/stage/published/threads/thread_WatzbMTVrhyTOLRUqs5Fgelj/runs/run_fabNNEICp0FQbb1dvSGoqHcauaIR/question/msg_iP4meOCcApZNjjh2kynrCsiL/source/foundry\\\"}\",\n            \"score\": 1,\n            \"knowledgeSourceIndex\": 0\n          }\n        ]\n      }",
