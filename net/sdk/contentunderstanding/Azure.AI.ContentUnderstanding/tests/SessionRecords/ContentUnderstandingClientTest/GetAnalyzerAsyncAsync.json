                "CurrencyCode": {
                  "type": "string",
                  "method": "generate"
                }
              }
            },
            "BillingAddress": {
              "type": "string",
              "method": "extract",
              "description": "Explicit billing address for the customer"
            },
            "BillingAddressRecipient": {
              "type": "string",
              "method": "extract",
              "description": "Name associated with the BillingAddress"
            },
            "CountryRegion": {
              "type": "string",
              "method": "generate",
              "description": "Country or region where the invoice was issued"
