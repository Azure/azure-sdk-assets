            },
            "InvoiceDate": {
              "type": "date",
              "method": "extract",
              "description": "Date the invoice was issued"
            },
            "InvoiceId": {
              "type": "string",
              "method": "extract",
              "description": "ID for this specific invoice (often 'Invoice Number')"
            },
