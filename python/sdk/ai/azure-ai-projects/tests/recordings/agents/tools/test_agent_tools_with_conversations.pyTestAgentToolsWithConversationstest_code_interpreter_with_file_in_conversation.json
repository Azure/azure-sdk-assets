            "code": "# clean numeric columns with commas\nnum_cols=['revenue','operating_expenses','operating_profit','depreciation','interest','profit_before_tax','tax','net_profit','EPS','profit_TTM','EPS_TTM']\nfor c in num_cols:\n    df[c]=df[c].astype(str).str.replace(',','', regex=False)\n    df[c]=pd.to_numeric(df[c], errors='coerce')\ntrans=df[df['sector'].str.upper()=='TRANSPORTATION'].copy()\ntrans[['name','operating_profit']]\n",
