              "type": "array",
              "method": "generate",
              "description": "List of line items",
              "items": {
                "type": "object",
                "method": "generate",
                "properties": {
                  "Date": {
                    "type": "date",
                    "method": "extract",
                    "description": "Date corresponding to each line item. Often it is a date the line item was shipped"
                  },
                  "Description": {
                    "type": "string",
                    "method": "extract",
                    "description": "The text description for the invoice line item"
                  },
                  "ProductCode": {
                    "type": "string",
                    "method": "extract",
                    "description": "Product code, product number, or SKU associated with the specific line item"
                  },
                  "Quantity": {
                    "type": "number",
                    "method": "extract",
                    "description": "The quantity for this invoice line item"
                  },
                  "QuantityUnit": {
                    "type": "string",
                    "method": "extract",
                    "description": "The unit of the line item, e.g., kg, lb, hours"
                  },
                  "TaxAmount": {
                    "type": "object",
                    "method": "generate",
                    "description": "Tax associated with each line item",
                    "properties": {
                      "Amount": {
                        "type": "number",
                        "method": "extract"
                      },
                      "CurrencyCode": {
                        "type": "string",
                        "method": "generate"
                      }
                    }
                  },
                  "TaxRate": {
                    "type": "number",
                    "method": "extract",
                    "description": "Tax rate associated with each line item (decimal fraction)"
