                "method": "generate",
                "properties": {
                  "Amount": {
                    "type": "object",
                    "method": "generate",
                    "description": "The amount of the tax detail",
                    "properties": {
                      "Amount": {
                        "type": "number",
                        "method": "extract"
                      },
                      "CurrencyCode": {
                        "type": "string",
                        "method": "generate"
                      }
                    }
                  },
                  "Description": {
                    "type": "string",
                    "method": "extract",
                    "description": "The description of the tax detail"
                  },
                  "NetAmount": {
                    "type": "object",
                    "method": "generate",
                    "description": "The net amount before tax.",
                    "properties": {
                      "Amount": {
                        "type": "number",
                        "method": "extract"
                      },
                      "CurrencyCode": {
                        "type": "string",
                        "method": "generate"
                      }
                    }
                  },
                  "Rate": {
                    "type": "number",
                    "method": "extract",
                    "description": "The rate of the tax detail (decimal fraction)"
                  }
                }
              }
            },
            "TotalAmount": {
              "type": "object",
              "method": "generate",
