                        "type": "number",
                        "method": "extract"
                      },
                      "CurrencyCode": {
                        "type": "string",
                        "method": "generate"
                      }
                    }
                  },
                  "UnitPrice": {
                    "type": "object",
                    "method": "generate",
                    "description": "The net or gross price (depending on the gross invoice setting of the invoice) of one unit of this item",
                    "properties": {
                      "Amount": {
                        "type": "number",
                        "method": "extract"
                      },
                      "CurrencyCode": {
                        "type": "string",
                        "method": "generate"
                      }
                    }
                  }
                }
              }
            },
            "PaymentTerm": {
              "type": "string",
              "method": "extract",
              "description": "The terms under which the payment is meant to be paid"
            },
            "PONumber": {
              "type": "string",
              "method": "extract",
