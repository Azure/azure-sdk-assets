                "definition": {
                  "kind": "workflow",
                  "beginWorkflow": {
                    "kind": "OnActivity",
                    "id": "activity1",
                    "actions": [
                      {
                        "kind": "SetVariable",
                        "id": "set_variable_input_task",
                        "variable": "Workflow.InputTask",
                        "value": "=System.LastMessage"
                      },
                      {
                        "kind": "InvokeAzureAgent",
                        "id": "student_agent",
                        "description": "The student node",
                        "agent": {
                          "name": "StudentAgent"
                        },
                        "input": {
                          "messages": "=Workflow.InputTask"
