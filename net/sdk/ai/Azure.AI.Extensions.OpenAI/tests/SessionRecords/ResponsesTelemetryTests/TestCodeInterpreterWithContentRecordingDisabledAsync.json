            "container_id": "cntr_69d5945eff488190a001166dcfa1c5260e28ee8858a7f2e0",
            "code": "import numpy as np\nimport matplotlib.pyplot as plt\nfrom scipy.optimize import fsolve\n\n# Define the function\ndef func(x):\n    return np.sin(x) + x**2 - 42\n\n# Generate x values for plotting\nx_vals = np.linspace(-10, 10, 400)\ny_vals = func(x_vals)\n\n# Plot the function\nplt.plot(x_vals, y_vals, label='sin(x) + x^2 - 42')\nplt.axhline(0, color='black', linewidth=0.5)\nplt.xlabel('x')\nplt.ylabel('f(x)')\nplt.title('Plot of the function sin(x) + x^2 - 42')\nplt.legend()\nplt.grid(True)\nplt.show()",
