              }
            },
            "TotalTaxAmount": {
              "type": "object",
              "method": "generate",
              "description": "Total tax field identified on this invoice",
              "properties": {
                "Amount": {
                  "type": "number",
                  "method": "generate"
                },
                "CurrencyCode": {
                  "type": "string",
                  "method": "generate"
