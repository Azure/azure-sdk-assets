            "output": "{\n        \"documents\": [\n          {\n            \"id\": \"6a907571-dcaa-405d-a6a3-6d724aefbde8\",\n            \"content\": \"I attempted to fetch an overview of the available tables, fields, metrics, and examples but encountered a technical issue with the database query. As a result, I was unable to retrieve the structural details.\\n\\nIf you are interested in a specific type of record or table (for example, sales records, weather data, or another domain), please specify what you're looking for, and I can attempt a more targeted query or provide guidance on possible next steps. Let me know how you'd like to proceed!\\n\",\n            \"filepath\": \"fabric://response\",\n            \"title\": \"Fabric Response for: sales records overview what tables fields metrics examples\",\n            \"url\": \"https://msit.fabric.microsoft.com/groups/409e30ce-b2ad-4c80-a54d-d645227322e4/aiskills/98042b9e-11cb-422d-bd97-5873411aa7c8/stage/published/threads/thread_bNUyFIodgOY8fChpI1OUVBEw/runs/run_fabgguDjASLu2dswNNSVUIwOMs6N/question/msg_BHnbYVlTqsy94t7ZJSgz3gxI/source/foundry\",\n            \"metadata\": \"{\\\"source\\\":\\\"azure_fabric\\\",\\\"query\\\":\\\"sales records overview what tables fields metrics examples\\\",\\\"data_agent_url\\\":\\\"https://msit.fabric.microsoft.com/groups/409e30ce-b2ad-4c80-a54d-d645227322e4/aiskills/98042b9e-11cb-422d-bd97-5873411aa7c8/stage/published/threads/thread_bNUyFIodgOY8fChpI1OUVBEw/runs/run_fabgguDjASLu2dswNNSVUIwOMs6N/question/msg_BHnbYVlTqsy94t7ZJSgz3gxI/source/foundry\\\"}\",\n            \"score\": 1,\n            \"knowledgeSourceIndex\": 0\n          }\n        ]\n      }",
