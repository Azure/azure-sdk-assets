              "type": "object",
              "method": "generate",
              "description": "Subtotal field identified on this invoice",
              "properties": {
                "Amount": {
                  "type": "number",
                  "method": "generate"
                },
                "CurrencyCode": {
                  "type": "string",
                  "method": "generate"
                }
              }
            },
            "TaxDetails": {
              "type": "array",
              "method": "generate",
