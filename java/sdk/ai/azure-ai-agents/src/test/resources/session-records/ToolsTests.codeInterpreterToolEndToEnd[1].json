            "container_id": "cntr_69aedf37414c8190840ac298246910700089776c053e45b0",
            "code": "def is_prime(n):\n    \"\"\"Check if a number is prime.\"\"\"\n    if n <= 1:\n        return False\n    if n <= 3:\n        return True\n    if n % 2 == 0 or n % 3 == 0:\n        return False\n    i = 5\n    while i * i <= n:\n        if n % i == 0 or n % (i + 2) == 0:\n            return False\n        i += 6\n    return True\n\ndef find_first_n_primes(n):\n    \"\"\"Find the first n prime numbers.\"\"\"\n    primes = []\n    num = 2\n    while len(primes) < n:\n        if is_prime(num):\n            primes.append(num)\n        num += 1\n    return primes\n\n# Calculate the first 10 prime numbers\nfirst_10_primes = find_first_n_primes(10)\nfirst_10_primes\n",
