            "container_id": "cntr_6a188e6bc9b481908d246f33ee28b353020e6a30898f99ea",
            "code": "from scipy.optimize import root_scalar\n\n# Try to find a root near positive sqrt(42)\nroot_pos = root_scalar(f, bracket=[6, 7], method='bisect')\n# Try to find a root near negative sqrt(42)\nroot_neg = root_scalar(f, bracket=[-7, -6], method='bisect')\n\nroot_pos.solution, root_neg.solution",
